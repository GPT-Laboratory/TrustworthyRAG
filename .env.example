# FARMI API access for LLM generation (Tampere University GPT Lab cluster).
# Copy this file to ".env" and fill in your own credentials:
#   cp .env.example .env
# Never commit the real .env file or hardcode the key in source code.

FARMI_API_URL=https://gptlab.rd.tuni.fi/students/ollama/v1
FARMI_API_KEY=your-api-key-here

# Optional: pin the generator model non-interactively (see configs/config.yaml).
# LLM_MODEL=llama3.3:70b
